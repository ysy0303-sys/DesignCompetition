# MySQL 数据库配置
DB_HOST=mysql.railway.internal  # 比如 junction.proxy.rlwy.net
DB_PORT=3306  # 比如 57245
DB_USER=root       # Railway 给的用户名
DB_PASSWORD=txyANZhrHPgGJOEneCWdexKtkdAWtLuj # Railway 给的密码
DB_NAME=education  # 你自己在这个 MySQL 服务里创建的数据库
#education

# 连接池配置（可选，生产环境下建议开启）
DB_POOL_SIZE=5
# ====================== FastAPI服务配置 ======================
# 服务运行端口（和前端匹配）
API_PORT=8000
# 服务运行主机（0.0.0.0允许局域网访问）
API_HOST=0.0.0.0
# 是否开启热重载（开发环境true，生产环境false）
API_RELOAD=true


# ========== 豆包 API 配置（核心修改） ==========
# 1. 豆包 API Key（必须替换为你自己的，获取方式见下文）
LLM_API_KEY=e3cf0432-34dd-4bfd-80ba-ff1d9ff318f5
# 2. 豆包 API 基础地址（固定值，不用改）
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# 火山方舟地址
LLM_MODEL=doubao-1-5-pro-32k-250115
# 示例中的模型名
# 4. 超时时间
LLM_TIMEOUT=180

# 任务配置
MAX_PLAN_DAYS=730
DEFAULT_DAILY_HOURS=2.0

